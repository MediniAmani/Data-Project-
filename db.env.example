# Local PostgreSQL connection (no Docker).
# Copy this file to db.env and set PGPASSWORD to your Windows Postgres password.
#
#   copy db.env.example db.env
#
# Apply schema into the default postgres database:
#   "C:\Program Files\PostgreSQL\17\bin\psql.exe" -U postgres -d postgres -f sql\001_star_schema.sql

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=REPLACE_WITH_YOUR_POSTGRES_PASSWORD
PGDATABASE=postgres
PGSCHEMA=airport_authority
